# Copy to: src/main/resources/application-local.properties
# (that file is gitignored — never commit secrets)

# --- Supabase Database (same project as Attendance Management System) ---
# Dashboard: Project Settings -> Database -> Connection string (Session Pooler)
spring.datasource.url=${SUPABASE_DB_URL:jdbc:postgresql://aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres?sslmode=require}
spring.datasource.username=${SUPABASE_DB_USER:postgres.YOUR_PROJECT_REF}
spring.datasource.password=${SUPABASE_DB_PASSWORD:your-database-password}

# PgBouncer / Session Pooler compatibility (also set in application.properties)
spring.datasource.hikari.data-source-properties.prepareThreshold=0
spring.jpa.properties.hibernate.jdbc.use_server_prep_stmts=false

# Library schema (isolates tables from Attendance public schema)
spring.jpa.properties.hibernate.default_schema=library
spring.jpa.properties.hibernate.create_namespaces=true
spring.datasource.hikari.connection-init-sql=CREATE SCHEMA IF NOT EXISTS library

# --- LU Centralized System — Brevo (HTTPS preferred; SMTP fallback) ---
# Railway: set BREVO_API_KEY (required on Hobby). Optional SMTP: MAIL_PASSWORD / BREVO_SMTP_PASSWORD
spring.mail.username=${MAIL_USERNAME:b20400001@smtp-brevo.com}
spring.mail.password=${MAIL_PASSWORD:${BREVO_SMTP_PASSWORD:}}
central.mail.brevo-api-key=${BREVO_API_KEY:}
central.mail.from-name=LU Centralized System
central.mail.from-email=edulibrary67@gmail.com
library.mail.from=edulibrary67@gmail.com
